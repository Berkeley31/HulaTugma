<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HulaTugma</title>
    <script type="importmap"></script>
    @* <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" /> *@
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="icon" type="image/png" href="~/hulatugma-sm.png" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Wordle.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="mx-auto px-4 max-w-screen-lg container-type min-h-screen mb-16">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted ">
        <div class="mx-auto px-4 max-w-screen-lg container-type">
            &copy; 2026 - HulaTugma ni Berkeley Aieca Castor - Demong Proyekto
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
